<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/primary_40" />
            <size android:width="200dp" android:height="200dp" />
        </shape>
    </item>
    <item android:top="20dp" android:bottom="20dp" android:left="20dp" android:right="20dp">
        <shape android:shape="oval">
            <stroke android:width="4dp" android:color="@color/secondary_40" />
        </shape>
    </item>
    <item android:top="40dp" android:bottom="40dp" android:left="40dp" android:right="40dp">
        <shape android:shape="oval">
            <solid android:color="@color/primary_20" />
        </shape>
    </item>
</layer-list>