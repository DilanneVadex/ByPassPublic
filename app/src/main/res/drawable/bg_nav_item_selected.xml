<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item
        android:left="2dp"
        android:top="2dp">
        <shape>
            <solid android:color="#40000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Main content layer -->
    <item
        android:bottom="2dp"
        android:right="2dp">
        <shape>
            <solid android:color="@color/secondary" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
